DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
WEB_ORIGIN="http://localhost:3000"

# Public base URL — used to build invite + share-link URLs in outgoing emails
# and in the SharePopover "Publish" tab. In dev: http://localhost:3000.
# In prod: https://www.octofocus.ai.
PUBLIC_APP_URL="http://localhost:3000"

# Transactional email (Resend). Leave RESEND_API_KEY empty during local dev —
# EmailService falls back to logging the invite payload so the share flow
# stays exercisable without DNS setup.
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxx"
# RESEND_FROM="OctoFocusAI <noreply@octofocus.ai>"

NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# tldraw license key (NEXT_PUBLIC_ so it ships to the client bundle).
# Without it, tldraw v5+ hides the canvas after 5 seconds on production
# domains as a license enforcement. localhost is exempt. Free watermarked
# license available from sales@tldraw.com.
# NEXT_PUBLIC_TLDRAW_LICENSE_KEY="tldraw-..."
