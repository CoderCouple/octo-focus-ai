    label: z.string(),
    children: z.array(MindmapNode).default([]),
  });

  export const FlashcardsSpec = z.object({
    kind: z.literal("flashcards"),
    cards: z.array(z.object({
      id: z.string(),
      front: z.string(),
      back: z.string(),
      tags: z.array(z.string()).default([]),
    })),
  });

  export const QuizSpec = z.object({
    kind: z.literal("quiz"),
    questions: z.array(z.object({
      id: z.string(),
      question: z.string(),
      choices: z.array(z.string()).min(2),
      correctIndex: z.number().int(),
      explanation: z.string().optional(),
    })),
  });

  export const InfographicSpec = z.object({
    kind: z.literal("infographic"),
    title: z.string(),
    blocks: z.discriminatedUnion("type", [
      z.object({ type: z.literal("stat"), value: z.string(), label: z.string() }),
      z.object({ type: z.literal("comparison"), left: z.string(), right: z.string(), winner: z.enum(["left","right"]).optional() }),
      z.object({ type: z.literal("bullets"), heading: z.string(), items: z.array(z.string()) }),
      z.object({ type: z.literal("chart"), chartKind: z.enum(["bar","pie","line"]), data: z.array(z.object({ label: z.string(), value: z.number() })) }),
      z.object({ type: z.literal("quote"), text: z.string(), attribution: z.string().optional() }),
      z.object({ type: z.literal("process"), steps: z.array(z.string()) }),
    ]),
  });

  export const ArtifactSpec = z.discriminatedUnion("kind", [
    MindmapSpec, FlashcardsSpec, QuizSpec, InfographicSpec,
  ]);

